---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const proyectos = await getCollection('proyectos');


const services = [
	{
		title: 'Diseño a Medida',
		description: 'Planificamos cada pieza según tu espacio, estilo y necesidades reales de uso.',
		label: 'Diseño',
	},
	{
		title: 'Fabricación Artesanal',
		description: 'Utilizamos maderas sólidas como Conacaste, Cedro y Roble, tratadas para resistir el clima de nuestra región.',
		label: 'Taller',
	},
	{
		title: 'Instalación y Entrega',
		description: 'Nos encargamos de la entrega final para que cada mueble quede perfecto en su lugar.',
		label: 'Entrega',
	},
];

import foto1 from '../assets/puerta02.jpeg';
import foto2 from '../assets/escaleras.jpeg';
import foto3 from '../assets/zapatera.jpeg';

const destacados = [
    { img: foto1, title: 'Puerta de Cedro', time: '2 semanas' },
    { img: foto2, title: 'Escaleron', time: '4 semanas' },
    { img: foto3, title: 'Mueble exibidor', time: '4 semanas' }
];
---

<Layout>
	<main class="overflow-x-hidden">
		<section id="inicio" class="relative min-h-screen flex items-center bg-stone-900 pt-28 pb-24 overflow-hidden">
			<div class="absolute inset-0 bg-linear-to-b from-stone-900 to-stone-950"></div>

			<div class="relative z-10 max-w-6xl mx-auto px-6 grid lg:grid-cols-[1.05fr_1fr] gap-16 lg:gap-10 items-center w-full">
				<div>
					<h1 class="font-display text-4xl sm:text-5xl lg:text-[3.35rem] font-semibold text-white leading-[1.08]">
						Transformamos madera <span class="italic text-amber-400">en el alma</span> de tu hogar
					</h1>
					<p class="text-lg text-stone-300 mt-6 max-w-xl">
						Muebles de alta gama diseñados con precisión y fabricados a mano en El Salvador. Calidad que se hereda.
					</p>

					<div class="mt-9 flex flex-wrap gap-4">
						<a href="#proyectos" class="bg-amber-600 hover:bg-amber-500 text-white px-7 py-3 rounded-lg font-semibold transition">
							Explorar Proyectos
						</a>
						<a href="#contacto" class="border border-white/30 hover:border-white text-white px-7 py-3 rounded-lg font-semibold transition">
							Solicitar Cotización
						</a>
					</div>

					<div class="mt-14 flex gap-10 max-w-md border-t border-white/10 pt-8">
						<div>
							<p class="font-display text-3xl text-white">+180</p>
							<p class="text-sm text-stone-400 mt-1">Proyectos</p>
						</div>
						<div>
							<p class="font-display text-3xl text-white">19 años</p>
							<p class="text-sm text-stone-400 mt-1">Experiencia</p>
						</div>
						<div>
							<p class="font-display text-3xl text-white">100%</p>
							<p class="text-sm text-stone-400 mt-1">A medida</p>
						</div>
					</div>
				</div>

				<div class="relative">
				    <div class="relative aspect-4/5 rounded-3xl overflow-hidden shadow-2xl ring-1 ring-white/10">
        {destacados.map((proy, index) => (
            <div
                class={`carousel-item absolute inset-0 transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                data-index={index}>
                <Image src={proy.img} alt={proy.title} class="h-full w-full object-cover" />
            </div>
        ))}
        <div class="absolute inset-0 bg-linear-to-t from-stone-950/60 via-transparent to-transparent"></div>
    </div>

					<div class="mx-auto mt-4 w-[min(92%,18rem)] rounded-2xl border border-white/12 bg-stone-950/75 px-4 py-3 shadow-2xl backdrop-blur-md">
						<div class="mb-2 inline-flex items-center gap-2 rounded-full border border-amber-400/20 bg-amber-400/10 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-amber-200">
						</span>
							Proyecto destacado
						</div>
						<div class="flex items-center justify-between gap-3">
							<p id="carousel-title" class="font-display text-lg font-semibold text-white leading-tight">{destacados[0].title}</p>
							<p id="carousel-time" class="shrink-0 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-amber-300">{destacados[0].time}</p>
						</div>
					</div>
</div>
		</section>

		<section class="py-20 md:py-24 bg-white border-y border-stone-200">
			<div class="max-w-6xl mx-auto px-6">
				<p class="text-amber-700 font-semibold mb-2 tracking-wide uppercase text-sm">Qué hacemos</p>
				<h2 class="font-display text-3xl md:text-4xl text-stone-900 mb-14 max-w-2xl">Del boceto a la instalación final</h2>

				<div class="grid sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-stone-200">
    {services.map((service, i) => (
        <div class="pt-8 sm:pt-0 sm:px-8 first:pt-0 first:sm:pl-0 last:sm:pr-0">
            <div class="flex items-center gap-3 mb-5">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-amber-600 font-display text-sm font-semibold text-white">
                    {i + 1}
                </span>
                <span class="h-px flex-1 bg-stone-200"></span>
            </div>
            <h3 class="text-xl font-bold text-stone-800 mb-3">{service.title}</h3>
            <p class="text-stone-600 leading-relaxed">{service.description}</p>
        </div>
    ))}
</div>
		</section>

		<section id="proyectos" class="py-24 max-w-6xl mx-auto px-6">
			<div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-14">
				<div>
					<p class="text-amber-700 font-semibold mb-2">Portafolio</p>
					<h2 class="font-display text-4xl font-semibold text-stone-800">Nuestros Trabajos</h2>
					<p class="text-stone-600 mt-3 max-w-2xl">
						Aqui se muestra una selección de muebles realizados a medida para clientes en El Salvador, destacando la variedad de estilos y materiales que trabajamos.
					</p>
				</div>
				<a href="#contacto" class="text-stone-800 font-semibold hover:text-amber-700 transition">Cotizar un proyecto →</a>
			</div>

			<div class="columns-1 sm:columns-2 lg:columns-3 gap-6">
				{proyectos.map((proyecto) => (
					<div class="mb-6 break-inside-avoid">
						<ProjectCard
						title={proyecto.data.title}
						material={proyecto.data.material}
						imagePath={proyecto.data.image}
						alt={proyecto.data.alt}
						/>
					</div>
				))}
			</div>
		</section>

		<section class="py-20 bg-stone-900 text-white">
			<div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-8">
				<div class="md:col-span-1">
					<p class="text-amber-400 font-semibold mb-2">Proceso de Trabajo</p>
					<h2 class="font-display text-3xl font-semibold">Simple, claro y personalizado</h2>
				</div>
				<div class="md:col-span-2 grid sm:grid-cols-3 gap-5">
					<div class="bg-white/10 rounded-xl p-5 border border-white/15">
						<p class="text-amber-400 font-semibold">01</p>
						<h3 class="font-bold mt-2">Consulta</h3>
						<p class="text-sm text-stone-300 mt-2">Definimos necesidades, medidas y estilo.</p>
					</div>
					<div class="bg-white/10 rounded-xl p-5 border border-white/15">
						<p class="text-amber-400 font-semibold">02</p>
						<h3 class="font-bold mt-2">Producción</h3>
						<p class="text-sm text-stone-300 mt-2">Fabricamos con materiales y acabados seleccionados.</p>
					</div>
					<div class="bg-white/10 rounded-xl p-5 border border-white/15">
						<p class="text-amber-400 font-semibold">03</p>
						<h3 class="font-bold mt-2">Entrega</h3>
						<p class="text-sm text-stone-300 mt-2">Instalamos y validamos cada detalle contigo.</p>
					</div>
				</div>
			</div>
		</section>

		<section id="contacto" class="py-24 bg-stone-100 px-6">
			<div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-8 items-stretch">
				<div class="lg:col-span-2 bg-stone-900 text-white rounded-2xl p-8">
					<p class="text-amber-400 font-semibold mb-2">Contacto</p>
					<h2 class="font-display text-3xl font-semibold mb-4">Cotiza tu Proyecto</h2>
					<p class="text-stone-300 mb-8">
						Desde un pequeño detalle hasta la cocina de tus sueños. Cuéntanos qué necesitas y te enviaremos una propuesta detallada
					</p>
					<div class="space-y-4 text-sm">
						<div class="rounded-lg bg-white/10 p-4 border border-white/10">
							<p class="text-stone-300">Tiempo de respuesta</p>
							<p class="font-semibold mt-1">Menos de 24 horas</p>
						</div>
						<div class="rounded-lg bg-white/10 p-4 border border-white/10">
							<p class="text-stone-300">Atención</p>
							<p class="font-semibold mt-1">Lunes a Sábado</p>
						</div>
					</div>
				</div>

				<div class="lg:col-span-3 bg-white p-8 md:p-10 rounded-2xl shadow-xl border border-stone-200">
					<form 
    					action="https://formspree.io/f/xwvrrelq" 
    					method="POST"
    					id="contact-form"
    					class="space-y-6"
						>
    				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        			<div>
            		<label class="block text-sm font-medium mb-2 text-stone-700">Nombre</label>
            		<input 
    					type="text" 
    					name="nombre" 
    					required 
    					class="w-full p-3 border border-stone-300 rounded-lg outline-none focus:ring-2 focus:ring-amber-600 
    					group-[.was-validated]:invalid:border-red-500 
    					group-[.was-validated]:invalid:text-red-600" 
    					placeholder="Tu nombre" 
					/>
					<p class="mt-1 hidden peer-user-invalid:block text-red-500 text-xs">
    					Por favor, ingresa un nombre valido.
					</p>
        		</div>
        			<div>
            		<label class="block text-sm font-medium mb-2 text-stone-700">Email</label>
            		<input 
    					type="email" 
   					 	name="email" 
    					required 
    					class="peer w-full p-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-amber-600 
						group-[.was-validated]:invalid:border-red-500 
    					group-[.was-validated]:invalid:text-red-600"  
    					placeholder="correo@ejemplo.com" 
					/>
					<p class="mt-1 hidden peer-user-invalid:block text-red-500 text-xs">
    					Por favor, ingresa un correo electrónico válido.
					</p>
       			</div>
    		</div>
    				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
       				<div>
            			<label class="block text-sm font-medium mb-2 text-stone-700">Teléfono</label>
            			<input 
    						type="tel" 
    						name="telefono" 
    						required
							pattern="[267]{1}[0-9]{3}-?[0-9]{4}" 
    						class="peer w-full p-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-amber-600 
							group-[.was-validated]:invalid:border-red-500 
    						group-[.was-validated]:invalid:text-red-600"  
    						placeholder="7845-1234" 
						/>
						<p class="mt-1 hidden peer-user-invalid:block text-red-500 text-xs">
    						Por favor, ingresa un numero valido.
						</p>
        		</div>
        			<div>
            			<label class="block text-sm font-medium mb-2 text-stone-700">Tipo de proyecto</label>
            			<select name="tipo_proyecto" class="w-full p-3 border border-stone-300 rounded-lg focus:ring-2 focus:ring-amber-600 outline-none">
                			<option value="cocina">Cocina</option>
                			<option value="closet">Closet</option>
                			<option value="comedor">Comedor</option>
                			<option value="oficina">Oficina</option>
                			<option value="otro">Otro</option>
            	</select>
        		</div>
    		</div>
    				<div>
        			<label class="block text-sm font-medium mb-2 text-stone-700">¿Qué mueble necesitas?</label>
        				<textarea name="mensaje" required class="w-full p-3 border border-stone-300 rounded-lg h-32 outline-none focus:ring-2 focus:ring-amber-600" placeholder="Describe tu idea, medidas aproximadas y estilo."></textarea>
    			</div>
    				<button type="submit" id="submit-btn" class="w-full bg-stone-800 text-white py-4 rounded-lg font-bold hover:bg-stone-900 transition">
        			Enviar Mensaje
    			</button>
    				<p id="form-status" class="hidden text-center font-medium mt-4 text-green-600">¡Mensaje enviado con éxito! Nos contactaremos pronto.</p>
				</form>				
			</div>
			</div>
		</section>
	</main>
</Layout>

<script define:vars={{ destacados }}>
    let currentIndex = 0;
    const items = document.querySelectorAll('.carousel-item');
    const titleEl = document.getElementById('carousel-title');
    const timeEl = document.getElementById('carousel-time');

    function showNext() {
        //Ocultar actual
        items[currentIndex].classList.replace('opacity-100', 'opacity-0');
        
        //Calcular siguiente
        currentIndex = (currentIndex + 1) % destacados.length;
        
        //Mostrar siguiente
        items[currentIndex].classList.replace('opacity-0', 'opacity-100');
        
        //Actualizar textos
        if(titleEl) titleEl.textContent = destacados[currentIndex].title;
        if(timeEl) timeEl.textContent = destacados[currentIndex].time;
    }

    //Cambiar cada 3 segundos
    setInterval(showNext, 4000);
</script>

<script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const status = document.getElementById('form-status');
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;

    if (form) {
        form.addEventListener('submit', async (e) => {
            //Validar antes de enviar
            if (!form.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
                form.classList.add('was-validated');
                form.reportValidity(); //Muestra los mensajes de error del navegador
                return;
            }

            e.preventDefault();
            
            //Estado de carga
            btn.disabled = true;
            const originalText = btn.innerText;
            btn.innerText = 'Enviando...';

            const data = new FormData(form);
            
            try {
                const response = await fetch(form.action, {
                    method: form.method,
                    body: data,
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (response.ok) {
                    status?.classList.remove('hidden');
                    form.reset();
                    form.classList.remove('was-validated'); //Limpiamos los errores visuales
                    btn.innerText = '¡Enviado!';
                    
                    setTimeout(() => {
                        status?.classList.add('hidden');
                        btn.disabled = false;
                        btn.innerText = originalText;
                    }, 5000);
                } else {
                    throw new Error();
                }
            } catch (error) {
                alert('Hubo un error al enviar. Por favor intenta de nuevo.');
                btn.disabled = false;
                btn.innerText = originalText;
            }
        });
    }
</script>