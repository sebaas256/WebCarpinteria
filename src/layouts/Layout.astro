---
import '../styles/global.css';
//importamos el componente de Astro y la imagen del logo
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png'; //ruta de la imagen del logo
import WhatsaapBtn from '../components/WhatsaapBtn.astro';
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Carpintería González | Arte en Madera</title>
	</head>
	<body class="bg-stone-50 text-stone-900 scroll-smooth">

		<nav class="fixed inset-x-0 top-0 z-50 px-4 pt-4 md:px-6">
			<div class="max-w-6xl mx-auto">
				<div class="flex items-center justify-between rounded-2xl border border-white/15 bg-stone-950/70 px-5 py-4 text-white shadow-2xl backdrop-blur-xl">
					<a href="#inicio" class="flex items-center gap-3 shrink-0">
						<div class="h-12 w-12 md:h-16 md:w-16 rounded-xl overflow-hidden p-1.5 shadow-lg ring-1 ring-white/15 bg-white/5">
							<Image 
								src={logoImage} 
								alt="Logo Carpintería González" 
								width={120} 
								height={120}
								class="h-full w-full object-contain"
							/>
						</div>
						<div class="hidden sm:block leading-tight">
							<p class="text-xs uppercase tracking-[0.22em] text-stone-400">Carpintería</p>
							<p class="text-sm md:text-base font-semibold text-white">González</p>
						</div>
					</a>

					<div class="hidden md:flex items-center gap-2 rounded-full border border-white/10 bg-white/5 p-1 text-sm font-medium text-stone-200">
						<a href="#inicio" class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white">Inicio</a>
						<a href="#proyectos" class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white">Proyectos</a>
						<a href="#contacto" class="rounded-full px-4 py-2 transition hover:bg-white/10 hover:text-white">Contacto</a>
					</div>

					<div class="flex items-center gap-3">
						<span class="hidden lg:block text-sm text-stone-300">Diseño y fabricación a medida</span>
						<a href="#contacto" class="rounded-full bg-amber-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-amber-500">
							Cotizar
						</a>
					</div>
				</div>
			</div>
		</nav>

		<slot />

		<footer class="relative overflow-hidden bg-stone-950 text-stone-300">
			<div class="absolute inset-0">
				<div class="absolute left-0 top-0 h-72 w-72 rounded-full bg-amber-600/10 blur-3xl"></div>
				<div class="absolute right-0 bottom-0 h-72 w-72 rounded-full bg-white/5 blur-3xl"></div>
			</div>

			<div class="relative max-w-6xl mx-auto px-6 pt-16 pb-8">
				<div class="mb-12 grid gap-6 rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm lg:grid-cols-[1.6fr_1fr] lg:items-center">
					<div>
						<p class="text-sm font-semibold uppercase tracking-[0.25em] text-amber-400">Listo para comenzar</p>
						<h2 class="mt-3 text-3xl font-bold text-white md:text-4xl">Construyamos un espacio con carácter propio</h2>
					</div>
					<div class="flex flex-col gap-3 sm:flex-row lg:flex-col lg:items-end">
						<a href="#contacto" class="inline-flex justify-center rounded-xl bg-amber-600 px-6 py-3 font-semibold text-white transition hover:bg-amber-500">
							Solicitar propuesta
						</a>
						<a href="#proyectos" class="inline-flex justify-center rounded-xl border border-white/15 px-6 py-3 font-semibold text-white transition hover:bg-white/5">
							Ver portafolio
						</a>
					</div>
				</div>

				<div class="grid gap-10 border-b border-white/10 pb-10 md:grid-cols-2 lg:grid-cols-4">
					<div>
						<div class="flex items-center gap-3">
							<div class="h-20 w-20 overflow-hidden rounded-xl bg-white/5 p-1">
								<Image 
									src={logoImage} 
									alt="Logo González" 
									width={80} 
									height={80}
									class="h-full w-full object-contain"
								/>
							</div>
							<div>
								<p class="text-xs uppercase tracking-[0.3em] text-stone-500">Carpintería</p>
								<p class="text-lg font-semibold text-white">González</p>
							</div>
						</div>
						<p class="mt-4 text-sm leading-6 text-stone-400">
							Diseño, fabricación e instalación de muebles a medida con una estética cálida y contemporánea.
						</p>
					</div>

					<div>
						<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white">Navegación</h3>
						<ul class="mt-4 space-y-3 text-sm">
							<li><a href="#inicio" class="transition hover:text-amber-400">Inicio</a></li>
							<li><a href="#proyectos" class="transition hover:text-amber-400">Proyectos</a></li>
							<li><a href="#contacto" class="transition hover:text-amber-400">Contacto</a></li>
						</ul>
					</div>

					<div>
						<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white">Servicios</h3>
						<ul class="mt-4 space-y-3 text-sm text-stone-400">
							<li>Muebles residenciales</li>
							<li>Closets y cocinas</li>
							<li>Mobiliario corporativo</li>
						</ul>
					</div>

					<div>
						<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white">Contacto</h3>
						<ul class="mt-4 space-y-3 text-sm text-stone-400">
							<li>El Salvador</li>
							<li>WhatsApp disponible</li>
							<li>Instagram / Portafolio</li>
						</ul>
					</div>
				</div>

				<div class="flex flex-col gap-3 pt-6 text-sm text-stone-500 md:flex-row md:items-center md:justify-between">
					<p>© 2026 Carpintería González. Diseño de calidad en madera.</p>
					<div class="flex gap-5">
						<span class="transition hover:text-white cursor-pointer">Instagram</span>
						<span class="transition hover:text-white cursor-pointer">WhatsApp</span>
						<span class="transition hover:text-white cursor-pointer">Correo</span>
					</div>
				</div>
			</div>
		</footer>
		<WhatsaapBtn/>
	</body>
</html>